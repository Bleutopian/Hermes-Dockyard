{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Dockyard",
  "version": "0.1.0",
  "identifier": "com.hermesdockyard.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hermes Dockyard",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "Bleutopian",
    "copyright": "Copyright 2026 Bleutopian. Internal alpha.",
    "shortDescription": "Hermes Dockyard internal alpha desktop shell.",
    "longDescription": "Internal unsigned alpha for validating Hermes Dockyard desktop packaging, bundled resources, read-only backend checks, and the repair-local-resources proof.",
    "resources": {
      "../../../bin": "resources/bin",
      "../../../config": "resources/config",
      "../../../docker": "resources/docker",
      "../../../packaging": "resources/packaging",
      "../../../schemas": "resources/schemas",
      "../../../scripts": "resources/scripts",
      "../../../wsl": "resources/wsl",
      "../../../README.md": "resources/README.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": [
          "English"
        ],
        "startMenuFolder": "Hermes Dockyard"
      }
    }
  }
}
