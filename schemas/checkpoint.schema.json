{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-system.local/schemas/checkpoint.schema.json",
  "title": "Agent System operation checkpoint",
  "description": "Checkpoint contract for resumable mutating operations and privileged proof workflows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation_id",
    "operation_name",
    "phase",
    "started_at",
    "updated_at",
    "requires_elevation",
    "reboot_required",
    "resume_command",
    "last_error_code",
    "recovery_action"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "operation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Stable operation instance identifier used for checkpoint and audit correlation."
    },
    "operation_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Allowlisted mutating operation name, for example repair-local-resources."
    },
    "phase": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Current typed phase within the operation lifecycle."
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "waiting_for_elevation",
        "waiting_for_reboot",
        "failed",
        "completed",
        "cancelled"
      ],
      "description": "Optional normalized lifecycle state for UI and audit display."
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "requires_elevation": {
      "type": "boolean"
    },
    "reboot_required": {
      "type": "boolean"
    },
    "resume_command": {
      "type": "string",
      "minLength": 1,
      "description": "Explicit allowlisted resume entrypoint. UI must never synthesize arbitrary commands."
    },
    "last_error_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "description": "Most recent stable error code, or null when no error has been recorded."
    },
    "recovery_action": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable next step surfaced by the unelevated shell."
    },
    "phase_history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/phase_history_entry"
      },
      "description": "Optional append-only history of phase checkpoints written during execution."
    },
    "artifacts": {
      "$ref": "#/$defs/artifact_paths"
    },
    "result": {
      "type": "string",
      "enum": [
        "unknown",
        "success",
        "failed",
        "cancelled"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      },
      "description": "Operation-specific non-secret context safe for read-only diagnostics."
    }
  },
  "$defs": {
    "phase_history_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "entered_at",
        "idempotency"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "entered_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "idempotency": {
          "type": "string",
          "enum": [
            "retriable",
            "reconcile",
            "write-once"
          ],
          "description": "Declares how the phase behaves when resumed after interruption."
        },
        "result": {
          "type": "string",
          "enum": [
            "pending",
            "completed",
            "failed",
            "skipped"
          ]
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_path",
        "audit_log_path"
      ],
      "properties": {
        "checkpoint_path": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical checkpoint artifact path."
        },
        "audit_log_path": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical audit log artifact path."
        },
        "resource_manifest_path": {
          "type": "string",
          "minLength": 1,
          "description": "Resource reconciliation manifest path for repair-local-resources."
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": "1.0",
      "operation_id": "repair-local-resources-20260501T002500Z",
      "operation_name": "repair-local-resources",
      "phase": "copy-resources",
      "status": "in_progress",
      "started_at": "2026-05-01T00:25:00Z",
      "updated_at": "2026-05-01T00:25:10Z",
      "requires_elevation": true,
      "reboot_required": false,
      "resume_command": "agent-system repair-local-resources --resume repair-local-resources-20260501T002500Z",
      "last_error_code": null,
      "recovery_action": "Retry the allowlisted repair-local-resources operation.",
      "phase_history": [
        {
          "phase": "validate-bundle",
          "entered_at": "2026-05-01T00:25:00Z",
          "completed_at": "2026-05-01T00:25:03Z",
          "idempotency": "retriable",
          "result": "completed",
          "error_code": null
        },
        {
          "phase": "copy-resources",
          "entered_at": "2026-05-01T00:25:03Z",
          "completed_at": null,
          "idempotency": "reconcile",
          "result": "pending",
          "error_code": null
        }
      ],
      "artifacts": {
        "checkpoint_path": "%ProgramData%\\AgentSystem\\state\\operations\\repair-local-resources-20260501T002500Z.json",
        "audit_log_path": "%ProgramData%\\AgentSystem\\logs\\operations.jsonl",
        "resource_manifest_path": "%ProgramData%\\AgentSystem\\state\\resource-manifest.json"
      },
      "result": "unknown",
      "metadata": {
        "caller": "desktop-shell",
        "target_root": "%ProgramFiles%\\AgentSystem"
      }
    }
  ]
}
